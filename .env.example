# =============================================================================
# CCDash environment configuration — copy to `.env` and override as needed.
# All backend variables are read in `backend/config.py`. Frontend build flags
# use the `VITE_` prefix (consumed at bundle time by Vite).
#
# Auto-load behaviour (backend only):
#   The backend auto-loads this file at startup (`npm run dev` / direct Python).
#   Real process env, Docker `--env-file`, and CI variables always win because
#   the loader uses override=False (first value set wins). Skipped under pytest.
#   Create `.env.local` alongside `.env` for machine-local overrides; it takes
#   precedence over `.env` for the same reason.
#
# See:
#   - docs/setup-user-guide.md                        — full setup + config reference
#   - docs/guides/query-cache-tuning-guide.md         — query cache TTL + warming
#   - docs/guides/storage-profiles-guide.md           — local vs enterprise posture
#   - docs/guides/telemetry-exporter-guide.md         — SAM telemetry export
#   - docs/guides/cli-timeout-debugging.md            — CLI timeouts
#
# Recommended defaults are called out inline as "RECOMMENDED".
# =============================================================================


# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
# Google Gemini API key for server-side AI insights proxy (POST /api/ai/insight).
# The key is NEVER shipped in the client bundle; all requests are proxied through
# the backend. When unset, the endpoint returns {disabled: true} instead of an error.
# Optional; omit to disable dashboard AI insights.
CCDASH_GEMINI_API_KEY=your_key_here


# -----------------------------------------------------------------------------
# Server / transport
# -----------------------------------------------------------------------------
# Host/port used by startup scripts and process binds.
CCDASH_BACKEND_HOST=127.0.0.1
CCDASH_BACKEND_PORT=8000

# Explicit Vite proxy target for `/api` calls (defaults to host:port above).
CCDASH_API_PROXY_TARGET=http://127.0.0.1:8000

# Internal bind host/port (used by FastAPI app directly — normally leave unset).
# CCDASH_HOST=0.0.0.0
# CCDASH_PORT=8000

# CORS allowed origin for the frontend.
# CCDASH_FRONTEND_ORIGIN=http://localhost:3000

# Optional explicit Python interpreter (if python3/python is not on PATH).
# CCDASH_PYTHON=/usr/bin/python3

# Optional bearer token required on backend API requests when using the default
# hosted static bearer auth provider.
# CCDASH_API_BEARER_TOKEN=


# -----------------------------------------------------------------------------
# Shared runtime contract
# Used by API and worker in hosted mode, and by local/test when you need to
# override the default local-first posture.
# -----------------------------------------------------------------------------
# SQLite is the default for `local` posture. Hosted API/worker should resolve
# to `enterprise` + `postgres`.
# CCDASH_STORAGE_PROFILE=local
# CCDASH_DB_BACKEND=sqlite

# Local-only SQLite path. Hosted API/worker should not depend on this.
# CCDASH_DB_PATH=.ccdash.db

# Hosted secret: REQUIRED for API/worker when storage resolves to enterprise.
# Do not leave this at the local placeholder in hosted deployments.
# CCDASH_DATABASE_URL=postgresql://user:password@localhost/ccdash

# SQLite-only: raise busy timeout (ms) if you see `database is locked` under load.
# Default 30000 (floor 1000).
# CCDASH_SQLITE_BUSY_TIMEOUT_MS=30000


# -----------------------------------------------------------------------------
# Shared storage profile modifiers
# `local` keeps SQLite + filesystem as the operator model. `enterprise` is
# Postgres-first and is the only mode that may use a shared Postgres instance.
# -----------------------------------------------------------------------------
# CCDASH_STORAGE_SHARED_POSTGRES=false
# CCDASH_STORAGE_ISOLATION_MODE=dedicated
# CCDASH_STORAGE_SCHEMA=ccdash
# CCDASH_ENTERPRISE_FILESYSTEM_INGESTION_ENABLED=false


# -----------------------------------------------------------------------------
# Project selection / workspace paths
# -----------------------------------------------------------------------------
# Active project slug at boot. Overrides the "current" entry in projects.json.
# CCDASH_ACTIVE_PROJECT=

# Override the resolved project root (defaults to the repo root).
# CCDASH_PROJECT_ROOT=

# Override the data directory used by default paths (sessions/docs/progress).
# CCDASH_DATA_DIR=

# Ingestion roots for platform session discovery.
# CCDASH_CLAUDE_PROJECTS_ROOT=
# CCDASH_CODEX_SESSIONS_ROOT=
# CCDASH_SESSION_DISCOVERY_ROOT=

# Where to resolve integrations settings + repo workspace cache.
# CCDASH_INTEGRATIONS_SETTINGS_FILE=.ccdash-integrations.json
# CCDASH_REPO_WORKSPACE_CACHE_DIR=.ccdash-repo-cache

# Override path for test results ingestion.
# CCDASH_TEST_RESULTS_DIR=


# -----------------------------------------------------------------------------
# Feature gates (backend)
# Defaults in code: several of these are on by default. Uncomment to flip.
# -----------------------------------------------------------------------------
CCDASH_TEST_VISUALIZER_ENABLED=true
CCDASH_INTEGRITY_SIGNALS_ENABLED=true
CCDASH_LIVE_TEST_UPDATES_ENABLED=true
CCDASH_SEMANTIC_MAPPING_ENABLED=true
# SkillMeat integration is the parent gate for the four agentic flags below.
CCDASH_SKILLMEAT_INTEGRATION_ENABLED=true
CCDASH_AGENTIC_RECOMMENDATIONS_ENABLED=true
CCDASH_AGENTIC_WORKFLOW_ANALYTICS_ENABLED=true
CCDASH_SESSION_USAGE_ATTRIBUTION_ENABLED=true
CCDASH_SESSION_BLOCK_INSIGHTS_ENABLED=true
# Local artifact-intelligence read surfaces (snapshot/ranking/recommendations).
# Outbound SAM export stays separately gated by CCDASH_TELEMETRY_EXPORT_ENABLED
# and CCDASH_SAM_ARTIFACT_TELEMETRY_ENABLED below (keep those false locally).
CCDASH_ARTIFACT_INTELLIGENCE_ENABLED=true
# Launch-prep modal + planning pre-flight checks.
CCDASH_LAUNCH_PREP_ENABLED=true
CCDASH_PLANNING_CONTROL_PLANE_ENABLED=true
# Next-run preview in the feature modal (code default true; explicit here).
CCDASH_NEXT_RUN_PREVIEW_ENABLED=true
# Feature board v2 layout (code default true; explicit here).
CCDASH_FEATURE_SURFACE_V2_ENABLED=true
# Multi-Project Planning Command Center (cross-project aggregate board + active sessions).
# Gates the aggregate endpoints; the UI learns this at runtime via launch capabilities.
CCDASH_MULTI_PROJECT_COMMAND_CENTER_ENABLED=true
# Build-time fallback for the multi-project UI when the runtime capability
# response is unavailable (resilience default is off without this).
VITE_CCDASH_MULTI_PROJECT_COMMAND_CENTER_ENABLED=true
# Agent Review Council + MeatyWiki integration surfaces (off until those
# external surfaces are in use).
# CCDASH_ARC_ENABLED=false
# CCDASH_MEATYWIKI_ENABLED=false


# -----------------------------------------------------------------------------
# Frontend live-update toggles (read at Vite build time)
# Defaults below match current rollout; set to true as SSE stabilizes.
# When SSE is disabled (CCDASH_LIVE_*_ENABLED=false in backend), the frontend
# falls back to polling with a 30-second cadence for features/tests/ops queries
# to reduce server load. See "Live update transport tuning" below.
# -----------------------------------------------------------------------------
# Core live updates (already stable, default true).
VITE_CCDASH_LIVE_EXECUTION_ENABLED=true
VITE_CCDASH_LIVE_SESSIONS_ENABLED=true
# Active session transcript append delivery (stream individual tool calls in real-time).
# Default false; set true to append events without a full modal refetch.
VITE_CCDASH_LIVE_SESSION_TRANSCRIPT_APPEND_ENABLED=true
# Feature board and modal live invalidation via SSE (default false).
# Enable to receive real-time feature status updates instead of polling.
VITE_CCDASH_LIVE_FEATURES_ENABLED=true
# Test visualizer live invalidation via SSE (default false).
# Enable to receive real-time test result updates instead of polling.
# Requires CCDASH_LIVE_TEST_UPDATES_ENABLED=true on the backend (set above).
VITE_CCDASH_LIVE_TESTS_ENABLED=true
# Operations panel live invalidation via SSE (default false).
# Enable to receive real-time session/document invalidation instead of polling.
VITE_CCDASH_LIVE_OPS_ENABLED=true
# Frontend memory hardening (transcript ring buffer, doc pagination cap,
# in-flight request GC). Code default true; uncomment only to disable.
# VITE_CCDASH_MEMORY_GUARD_ENABLED=true


# -----------------------------------------------------------------------------
# Startup sync + link rebuild tuning  ★ performance-sensitive ★
# Change these first if startup feels slow or syncs feel repetitive.
# See: docs/sync-observability-and-audit.md
# -----------------------------------------------------------------------------
# Light-mode startup sync reduces cold-boot time. Keep true for local.
CCDASH_STARTUP_SYNC_LIGHT_MODE=true
# Delay before the startup sync kicks off (seconds).
CCDASH_STARTUP_SYNC_DELAY_SECONDS=2
# Deferred link rebuild runs a second, heavier rebuild after startup. Default
# is false (off); set to `true` only when full link graph freshness at boot is
# required (e.g. production or CI environments with infrequent restarts).
CCDASH_STARTUP_DEFERRED_REBUILD_LINKS=false
CCDASH_STARTUP_DEFERRED_REBUILD_DELAY_SECONDS=45
CCDASH_STARTUP_DEFERRED_CAPTURE_ANALYTICS=false
# Incremental (scope=entities_changed) link rebuild on the watcher hot path. Default true
# (flipped in Phase 4 — CCDash Core Remediation). When true, new/changed JSONL triggers
# rebuild_links_for_entities (family-scoped, no filesystem walk) instead of the global
# _rebuild_entity_links scan. Set false/0 to revert to full-scan fallback.
CCDASH_INCREMENTAL_LINK_REBUILD_ENABLED=true

# Bump this when link inference logic changes and you need a full relink.
# Normal startup skips relinking when cached entities are unchanged.
CCDASH_LINKING_LOGIC_VERSION=1

# Analytics snapshot cadence for scheduled jobs (seconds).
# CCDASH_ANALYTICS_SNAPSHOT_INTERVAL_SECONDS=900


# -----------------------------------------------------------------------------
# Live update transport tuning (SSE + polling fallback)
# See: docs/guides/setup.md, docs/guides/containerized-deployment-quickstart.md
# Affected features: VITE_CCDASH_LIVE_FEATURES_ENABLED, VITE_CCDASH_LIVE_TESTS_ENABLED,
#                   VITE_CCDASH_LIVE_OPS_ENABLED
# When SSE is off, frontend falls back to TanStack Query polling (30s cadence).
# When SSE is on, frontend receives real-time invalidation without polling.
# Tune transport settings to match your deployment model (local vs enterprise).
# -----------------------------------------------------------------------------
# NOTE: there is no global SSE master gate — opt in per surface via the
# VITE_CCDASH_LIVE_*_ENABLED flags above (plus CCDASH_LIVE_TEST_UPDATES_ENABLED
# on the backend for tests). When a surface's SSE flag is off, the frontend
# falls back to 30-second polling. Local HTTP can always use SSE; behind a
# load balancer ensure streaming is supported (e.g., Nginx proxy_buffering off).
# Replay buffer depth (events retained per topic for reconnecting clients).
# Default: 200 events. Reduce on memory-constrained deployments.
# CCDASH_LIVE_REPLAY_BUFFER_SIZE=200
# Heartbeat cadence (seconds) for SSE keep-alive (prevents proxy timeouts).
# Default: 15 seconds. Increase for slow/unstable networks.
# CCDASH_LIVE_HEARTBEAT_SECONDS=15
# Max pending events per subscriber before coarse invalidation is forced.
# Default: 100 events. Raise on high-concurrency deployments.
# CCDASH_LIVE_MAX_PENDING_EVENTS=100
# Per-topic event cache TTL for live-count service (default 10 seconds).
# Increase to reduce event processing overhead on low-update-cadence deployments.
# CCDASH_LIVE_COUNT_CACHE_TTL_SECONDS=10
# Time window for live-agents aggregation (default 600 seconds / 10 minutes).
# Represents how far back the system looks when computing active session metrics.
# CCDASH_LIVE_AGENTS_WINDOW_SECONDS=600


# -----------------------------------------------------------------------------
# Agent query cache  ★ performance-sensitive ★
# In-process TTL cache for the four agent query endpoints
# (project-status, feature-forensics, workflow-diagnostics, AAR).
# See: docs/guides/query-cache-tuning-guide.md
# -----------------------------------------------------------------------------
# Cache backend: 'memory' (in-process TTLCache, default for local dev) or
# 'postgres' (shared query_cache table, enterprise default for cross-replica
# cache sharing). Set CCDASH_QUERY_CACHE_BACKEND=postgres in compose.yaml for
# the enterprise api + worker services; leave unset or 'memory' for local dev.
# CCDASH_QUERY_CACHE_BACKEND=memory

# Job queue backend: 'memory' (in-process scheduler, local default) or
# 'postgres' (durable Postgres-backed queue for enterprise multi-replica
# deployments — prevents job duplication and survives restarts).
# Enterprise deployments should set this to 'postgres' alongside CCDASH_QUERY_CACHE_BACKEND.
# CCDASH_JOB_QUEUE_BACKEND=memory

# Cache lifetime in seconds. 0 disables the cache. Default: 600.
# Paired with warmer interval (300s below): TTL covers 2 full warmer cycles so
# entries never expire between refreshes — eliminates cold-window misses.
CCDASH_QUERY_CACHE_TTL_SECONDS=600
# Worker cache-warming interval (seconds). 0 disables warming. Default: 300.
# Only active when the worker runtime is running (`npm run dev:worker`).
CCDASH_QUERY_CACHE_REFRESH_INTERVAL_SECONDS=300


# -----------------------------------------------------------------------------
# CLI
# -----------------------------------------------------------------------------
# Default HTTP timeout (seconds) for the standalone `ccdash` CLI.
# CCDASH_TIMEOUT=30
# Active target name for the CLI (see `ccdash target list`).
# CCDASH_TARGET=


# -----------------------------------------------------------------------------
# API-only contract
# -----------------------------------------------------------------------------
# Hosted auth provider. Defaults:
#   - local/test runtime: local no-auth
#   - hosted API runtime: static_bearer
# Supported values: static_bearer, clerk, oidc, local.
# CCDASH_AUTH_PROVIDER=static_bearer

# Static bearer provider secret. Required for hosted API when
# CCDASH_AUTH_PROVIDER is unset or static_bearer.
# CCDASH_API_BEARER_TOKEN=

# Explicit no-auth escape hatch. Local/test runtimes default to no-auth. Hosted
# API only accepts CCDASH_AUTH_PROVIDER=local when this is explicitly true.
# CCDASH_LOCAL_NO_AUTH_ENABLED=false

# Clerk provider settings. Required when CCDASH_AUTH_PROVIDER=clerk:
# CCDASH_CLERK_PUBLISHABLE_KEY=
# CCDASH_CLERK_SECRET_KEY=
# CCDASH_CLERK_JWT_KEY=
# Optional Clerk claim constraints:
# CCDASH_CLERK_AUTHORIZED_PARTIES=
# CCDASH_CLERK_AUDIENCE=

# Generic OIDC provider settings. Required when CCDASH_AUTH_PROVIDER=oidc:
# CCDASH_OIDC_ISSUER=
# CCDASH_OIDC_AUDIENCE=
# CCDASH_OIDC_CLIENT_ID=
# CCDASH_OIDC_CLIENT_SECRET=
# CCDASH_OIDC_CALLBACK_URL=
# CCDASH_OIDC_JWKS_URL=

# Hosted session cookie/proxy settings for future Clerk/OIDC adapters.
# CCDASH_SESSION_COOKIE_NAME=ccdash_session
# CCDASH_SESSION_COOKIE_SECURE=true
# CCDASH_SESSION_COOKIE_SAMESITE=lax
# CCDASH_SESSION_COOKIE_DOMAIN=
# CCDASH_TRUSTED_PROXY_ENABLED=false


# -----------------------------------------------------------------------------
# Worker-only contract
# -----------------------------------------------------------------------------
# Bind a background worker to a specific project slug. Required before the
# worker should own startup sync, warming, or scheduled jobs.
# CCDASH_WORKER_PROJECT_ID=

# Worker probe endpoint (for readiness/liveness in container deployments).
# CCDASH_WORKER_PROBE_HOST=127.0.0.1
# CCDASH_WORKER_PROBE_PORT=9465

# Enterprise live-ingest watcher worker. `worker-watch` co-runs with the
# default worker, owns filesystem watching, and is one project per process in
# v1. Use a distinct probe port for every watcher worker instance.
# CCDASH_WORKER_WATCH_PROJECT_ID: Optional scope filter for the watcher worker.
#   Empty → watcher derives targets from DB registry (all is_active=true projects).
#   Non-empty → scopes to that specific project id.
#   When empty, the watcher implements registry-driven fan-out and runs one
#   WatcherBinding per active project. When set, only that project is watched.
# CCDASH_WORKER_WATCH_PROJECT_ID=
# CCDASH_WORKER_WATCH_PROBE_HOST=0.0.0.0
# CCDASH_WORKER_WATCH_PROBE_PORT=9466
# CCDASH_WORKER_WATCH_FILESYSTEM_INGESTION_ENABLED=true
# Watcher sync concurrency — max parallel file sync operations per project.
# Default: 20. Increase on high-throughput deployments, decrease for memory-constrained.
# CCDASH_WATCHER_SYNC_CONCURRENCY=20
# Watcher reconcile interval — how often (seconds) the watcher re-reads the DB
# registry to detect added/removed/activated projects. Default: 60.
# Only relevant when CCDASH_WORKER_WATCH_PROJECT_ID is empty (registry-driven mode).
# CCDASH_WATCHER_RECONCILE_INTERVAL_SECONDS=60
# macOS Docker Desktop compatibility mode for bind-mounted session roots.
# WATCHFILES_FORCE_POLLING=true

# Optional extra read-only bind mount slots used by deploy/runtime/compose.yaml.
# Use these when a watched project/session root lives outside the main workspace,
# Claude home, or Codex home mounts. Set target equal to source for absolute
# projects.json paths.
# CCDASH_EXTRA_MOUNT_1_HOST=/absolute/host/path
# CCDASH_EXTRA_MOUNT_1_CONTAINER=/absolute/host/path
# CCDASH_EXTRA_MOUNT_2_HOST=/absolute/host/path
# CCDASH_EXTRA_MOUNT_2_CONTAINER=/absolute/host/path


# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# CCDASH_OTEL_ENABLED=false
# CCDASH_OTEL_ENDPOINT=http://localhost:4318
# CCDASH_OTEL_SERVICE_NAME=ccdash-backend
# CCDASH_PROM_PORT=9464


# Worker-only telemetry/export contract
# See: docs/guides/telemetry-exporter-guide.md
# -----------------------------------------------------------------------------
# Master switch for outbound telemetry export from the worker runtime.
CCDASH_TELEMETRY_EXPORT_ENABLED=false
# Base SAM API URL, e.g. https://sam.internal.
CCDASH_SAM_ENDPOINT=
# Bearer token used for SAM authentication.
CCDASH_SAM_API_KEY=
# Export job interval in seconds (minimum 60).
CCDASH_TELEMETRY_EXPORT_INTERVAL_SECONDS=900
# Queued events pushed per run (range 1-500).
CCDASH_TELEMETRY_EXPORT_BATCH_SIZE=50
# HTTP timeout (seconds) for export requests.
CCDASH_TELEMETRY_EXPORT_TIMEOUT_SECONDS=30
# Pending queue cap before new rows are dropped.
CCDASH_TELEMETRY_EXPORT_MAX_QUEUE_SIZE=10000
# Retention window (days) for synced queue rows.
CCDASH_TELEMETRY_QUEUE_RETENTION_DAYS=30
# Allow plaintext HTTP SAM endpoints for development only.
CCDASH_TELEMETRY_ALLOW_INSECURE=false
# Enable optional SAM artifact telemetry channel.
CCDASH_SAM_ARTIFACT_TELEMETRY_ENABLED=false
# Version emitted in telemetry payloads.
CCDASH_VERSION=0.1.0


# -----------------------------------------------------------------------------
# Local-only convenience overrides
# These support the local/test developer workflow and should not be treated as
# hosted API/worker requirements.
# -----------------------------------------------------------------------------
# CCDASH_SESSION_MAPPINGS_FILE=docs/session-mappings.overrides.json
# CCDASH_SESSION_MAPPINGS_JSON=[{"id":"key-dev-execute-phase","mappingType":"key_command","pattern":"^/dev:execute-phase\\b"}]


# -----------------------------------------------------------------------------
# GitHub integration (for project repo-source modes)
# -----------------------------------------------------------------------------
# CCDASH_GITHUB_TOKEN=
# CCDASH_GITHUB_USERNAME=
