# Google Gemini API key for AI-powered dashboard insights
GEMINI_API_KEY=your_key_here

# Backend host/port used by startup scripts
CCDASH_BACKEND_HOST=127.0.0.1
CCDASH_BACKEND_PORT=8000

# Storage profile contract. `local` keeps SQLite + filesystem as the default
# operator model. `enterprise` is Postgres-first and is the only mode that may
# use a shared Postgres instance.
# CCDASH_STORAGE_PROFILE=local
# CCDASH_STORAGE_SHARED_POSTGRES=false
# CCDASH_STORAGE_ISOLATION_MODE=dedicated
# CCDASH_STORAGE_SCHEMA=ccdash
# CCDASH_ENTERPRISE_FILESYSTEM_INGESTION_ENABLED=false

# Optional explicit proxy target for Vite (/api -> backend)
CCDASH_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional explicit Python interpreter (if python3/python is not on PATH)
# CCDASH_PYTHON=/usr/bin/python3

# Enable Test Visualizer API/routes (required for /tests page data)
CCDASH_TEST_VISUALIZER_ENABLED=true

# Optional test subsystem gates (project settings still apply via env && project logic)
CCDASH_INTEGRITY_SIGNALS_ENABLED=true
CCDASH_LIVE_TEST_UPDATES_ENABLED=true
CCDASH_SEMANTIC_MAPPING_ENABLED=true

# Frontend live-update rollout toggles (execution/sessions are on by default).
VITE_CCDASH_LIVE_EXECUTION_ENABLED=true
VITE_CCDASH_LIVE_SESSIONS_ENABLED=true
VITE_CCDASH_LIVE_SESSION_TRANSCRIPT_APPEND_ENABLED=true
VITE_CCDASH_LIVE_FEATURES_ENABLED=true
VITE_CCDASH_LIVE_TESTS_ENABLED=true
VITE_CCDASH_LIVE_OPS_ENABLED=true

# Bump this when link inference logic changes and you need a full relink.
# Normal startup skips relinking when cached entities are unchanged.
CCDASH_LINKING_LOGIC_VERSION=1

CCDASH_QUERY_CACHE_TTL_SECONDS=TTL=600

CCDASH_STARTUP_DEFERRED_REBUILD_LINKS=false

# Optional session mapping overrides loaded on top of DB mappings.
# CCDASH_SESSION_MAPPINGS_FILE=docs/session-mappings.overrides.json
# CCDASH_SESSION_MAPPINGS_JSON=[{"id":"key-dev-execute-phase","mappingType":"key_command","pattern":"^/dev:execute-phase\\b"}]

# Telemetry exporter to SAM (disabled by default for safety)
# bool, default false: master switch for outbound telemetry export.
CCDASH_TELEMETRY_EXPORT_ENABLED=true
# string, default empty: base SAM API URL, for example https://sam.internal
CCDASH_SAM_ENDPOINT=http://127.0.0.1:8080
# string, default empty: bearer token used for SAM authentication.
CCDASH_SAM_API_KEY=
# int, default 900: export job interval in seconds (minimum 60).
CCDASH_TELEMETRY_EXPORT_INTERVAL_SECONDS=900
# int, default 50: queued events pushed per run (range 1-500).
CCDASH_TELEMETRY_EXPORT_BATCH_SIZE=50
# int, default 30: HTTP timeout in seconds for export requests.
CCDASH_TELEMETRY_EXPORT_TIMEOUT_SECONDS=30
# int, default 10000: pending queue cap before new rows are dropped.
CCDASH_TELEMETRY_EXPORT_MAX_QUEUE_SIZE=10000
# int, default 30: retention window in days for synced queue rows.
CCDASH_TELEMETRY_QUEUE_RETENTION_DAYS=30
# bool, default false: allow plaintext HTTP SAM endpoints for development only.
CCDASH_TELEMETRY_ALLOW_INSECURE=false
# string, default 0.1.0: version emitted in telemetry payloads.
CCDASH_VERSION=0.1.0
