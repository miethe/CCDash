# CCDash local streaming worker — environment template
# ----------------------------------------------------------------------------
# Copy this file to ~/.ccdash/stream.env and fill in the real values.
# The real file is NOT committed (it lives outside the repo at ~/.ccdash/).
# Both wrappers (ccdash-stream-worker.sh / ccdash-register.sh) and the
# management CLI (ccdash-stream.sh) source it. Keeping secrets here keeps
# them out of the LaunchAgent plists.
#
# This is a shell file: `source`-d by bash. Use KEY=value, no spaces around `=`.
# ----------------------------------------------------------------------------

# --- Repo location (used by the wrappers to cd into the checkout) ----------
# The wrappers are copied to ~/.ccdash/bin/ at install time, so they cannot
# derive the repo from their own path. Point this at your CCDash checkout.
CCDASH_REPO="$HOME/dev/homelab/development/CCDash"

# --- Database: remote node Postgres (the shared DB the node API/UI read) ---
# The local worker watches Mac filesystem paths and writes to this remote DB.
CCDASH_DB_BACKEND=postgres
# Node Postgres DSN. Port 5440 is the node's exposed Postgres.
# Replace CHANGEME with the LAN dev password (currently: ccdash).
# Do NOT commit the real password — keep it only in ~/.ccdash/stream.env.
CCDASH_DATABASE_URL=postgresql://ccdash:CHANGEME@10.42.10.76:5440/ccdash

# --- Runtime profile -------------------------------------------------------
# worker-watch = filesystem-watch + per-project fan-out sync. Confirmed
# invocation: `python -m backend.worker` (deploy/runtime/entrypoint.sh).
CCDASH_RUNTIME_PROFILE=worker-watch

# --- Worker binding contract ----------------------------------------------
# REQUIRED non-empty for the worker/worker-watch profile (config.py worker
# binding validation). Set to a valid registered project id; the CCDash
# project id is the primary binding.
CCDASH_WORKER_PROJECT_ID=ccp-2a984316f63a
# MUST stay EMPTY so the watcher fans out to ALL registered projects from the
# DB registry. A non-empty value scopes the watcher to a single project id.
CCDASH_WORKER_WATCH_PROJECT_ID=

# --- Probe port ------------------------------------------------------------
# The worker exposes a liveness/readiness probe on this port (default 9465).
# 9466 avoids clashing with a local dev backend (8000) and a local dev worker
# (9465). Change if it conflicts with anything else running on your Mac.
CCDASH_WORKER_PROBE_HOST=127.0.0.1
CCDASH_WORKER_PROBE_PORT=9466

# --- Startup sync mode -----------------------------------------------------
# The worker reconciles all registered projects on startup. With KeepAlive +
# RunAtLoad, every login/restart would otherwise full-scan every session file
# (~10K+) before the watcher settles. Light mode skips the scan for paths whose
# manifest is unchanged, so restarts are fast and the watcher reaches ready in
# seconds; new/changed files are still picked up by the live watcher. Set 0 to
# force a full reconcile (e.g. first-ever run, or after a schema change).
CCDASH_STARTUP_SYNC_LIGHT_MODE=1

# --- Node API base (used by the register wrapper + `status` check) ---------
# Where the node serves the CCDash REST API. The register script POSTs new
# project registrations here; `ccdash-stream.sh status` GETs health from here.
CCDASH_API=http://10.42.10.76:8090

# --- Codex session ingestion (Phase 4 — codex-session-ingestion-v1) --------
# Enable ingestion of OpenAI Codex CLI rollout sessions into CCDash so they
# appear side-by-side with Claude Code sessions in the same projects.
# Set to 1 to enable; default is 0 (off).
CCDASH_CODEX_INGEST_ENABLED=0
#
# Path to the Codex sessions root directory on the Mac.  The worker scans this
# tree (YYYY/MM/DD/rollout-*.jsonl) for new/changed rollout files.
# Default: ~/.codex/sessions — set only if your Codex CLI writes elsewhere.
# CCDASH_CODEX_SESSIONS_PATH=~/.codex/sessions
#
# Number of days back to include in the initial bounded backfill sweep.
# The startup backfill only ingests rollout files whose date (from the
# YYYY/MM/DD tree structure, or file mtime) falls within [now - N days, now].
# The periodic reconcile pass always picks up new/changed files regardless of
# this window (mtime idempotency prevents duplicates).
# Set to 0 for a full historical backfill (ingests all ~1,769+ rollouts).
# Default: 7 (one week).
# CCDASH_CODEX_BACKFILL_DAYS=7
