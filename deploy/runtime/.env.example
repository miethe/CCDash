# Copy this file to deploy/runtime/.env and choose the matching compose profile set:
#   local                      => docker compose --env-file deploy/runtime/.env --profile local up
#   enterprise                 => docker compose --env-file deploy/runtime/.env --profile enterprise up
#   enterprise + bundled db    => docker compose --env-file deploy/runtime/.env --profile enterprise --profile postgres up
#   enterprise + live watcher  => docker compose --env-file deploy/runtime/.env --profile enterprise --profile postgres --profile live-watch up
#
# The `postgres` profile is additive. It supplies the bundled Postgres service
# for the enterprise stack; it is not meant to be run by itself.
#
# Rootless Podman notes:
# - Keep the named volumes from deploy/runtime/compose.yaml for writable app data.
# - Add `:Z` to any operator bind mounts you introduce on SELinux hosts
#   (for example `./projects.json:/app/projects.json:Z`).

# Compose assigns CCDASH_RUNTIME_PROFILE per service. Do not set it globally here.

# Google Gemini API key for server-side AI insights proxy (POST /api/ai/insight).
# The key is NEVER shipped in the client bundle; all requests are proxied through
# the backend. When unset, the endpoint returns {disabled: true} instead of an error.
# Optional; omit to disable dashboard AI insights.
# CCDASH_GEMINI_API_KEY=your_key_here

# Rootless Docker/Podman UID/GID mapping.
CCDASH_UID=1000
CCDASH_GID=1000
CCDASH_PROJECT_ROOT=/app
# Project registry mounted into backend containers. Relative paths resolve from
# deploy/runtime/compose.yaml, so ../../projects.json is the repo root file.
CCDASH_PROJECTS_FILE=../../projects.json
# Optional read-only ingest mounts. For projects.json entries with absolute host
# paths, set container targets to the same absolute paths so workers can read
# docs/sessions without rewriting project registry paths.
CCDASH_WORKSPACE_HOST_ROOT=../../..
CCDASH_WORKSPACE_CONTAINER_ROOT=/workspace
CCDASH_CLAUDE_HOME=~/.claude
CCDASH_CLAUDE_CONTAINER_HOME=/home/ccdash/.claude
CCDASH_CODEX_HOME=~/.codex
CCDASH_CODEX_CONTAINER_HOME=/home/ccdash/.codex

# Optional additional read-only mounts. Use these when a project registry points
# at host paths outside CCDASH_WORKSPACE_HOST_ROOT, CCDASH_CLAUDE_HOME, or
# CCDASH_CODEX_HOME. For absolute paths in projects.json, set the container
# target to the same absolute path so no path rewriting is needed.
# Unused slots default to checked-in empty directories so compose config works.
# CCDASH_EXTRA_MOUNT_1_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_1_CONTAINER=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_2_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_2_CONTAINER=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_3_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_3_CONTAINER=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_4_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_4_CONTAINER=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_5_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_5_CONTAINER=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_6_HOST=/absolute/host/project-or-session-root
# CCDASH_EXTRA_MOUNT_6_CONTAINER=/absolute/host/project-or-session-root

# Shared frontend and API settings.
CCDASH_API_PORT=8000
CCDASH_FRONTEND_PORT=3000
# Optional override. When unset, compose derives http://localhost:${CCDASH_FRONTEND_PORT}.
# CCDASH_FRONTEND_ORIGIN=http://localhost:3000
# The local backend service is aliased as `api`, so this works for both
# `local` and `enterprise` profiles unless you intentionally override it.
CCDASH_API_UPSTREAM=http://api:8000
VITE_CCDASH_API_BASE_URL=/api

# Local profile defaults.
CCDASH_DB_PATH=/var/lib/ccdash/ccdash.db

# Enterprise profile defaults.
CCDASH_STORAGE_PROFILE=enterprise
CCDASH_DB_BACKEND=postgres
# Leave this value when you enable the bundled `postgres` profile.
# If you change CCDASH_POSTGRES_USER/PASSWORD/DB below, update this DSN to match.
# Keep the service-internal port as 5432 for the bundled Compose Postgres service.
# CCDASH_POSTGRES_PORT only changes the host-published port.
# Replace it with your external Postgres DSN for enterprise-only deployments.
CCDASH_DATABASE_URL=postgresql://ccdash:ccdash@postgres:5432/ccdash
CCDASH_API_BEARER_TOKEN=ccdash-dev-token
# Required for worker readiness. Replace with a project id the workspace
# registry can resolve before you run the enterprise profile.
# The default worker and worker-watch bind one project id per worker process.
# Set CCDASH_WORKER_WATCH_PROJECT_ID when the watcher should ingest a different
# project from the scheduled worker.
CCDASH_WORKER_PROJECT_ID=REPLACE_WITH_RESOLVABLE_PROJECT_ID
CCDASH_WORKER_PROBE_HOST=0.0.0.0
CCDASH_WORKER_PROBE_PORT=9465

# Watcher worker profile. The `live-watch` profile co-runs with the default
# enterprise worker instead of replacing it, so use a distinct probe port.
# The watcher worker binds exactly one project id per process in v1; run a
# second worker-watch service with a different project id and probe port for
# another project.
CCDASH_WORKER_WATCH_PROBE_HOST=0.0.0.0
CCDASH_WORKER_WATCH_PROBE_PORT=9466
CCDASH_WORKER_WATCH_PROJECT_ID=REPLACE_WITH_RESOLVABLE_PROJECT_ID
CCDASH_WORKER_WATCH_FILESYSTEM_INGESTION_ENABLED=true
CCDASH_INFERRED_STATUS_WRITEBACK_ENABLED=false
GIT_OPTIONAL_LOCKS=0
# On macOS Docker Desktop, bind-mounted filesystem events may not propagate
# reliably. Enable polling for the worker-watch container when live ingest sees
# no changes after startup. The shipped compose file passes this variable only
# to worker-watch.
# WATCHFILES_FORCE_POLLING=true

# Shared-enterprise storage contract.
CCDASH_STORAGE_SHARED_POSTGRES=false
# Use `schema` or `tenant` when CCDASH_STORAGE_SHARED_POSTGRES=true.
CCDASH_STORAGE_ISOLATION_MODE=dedicated
CCDASH_STORAGE_SCHEMA=ccdash
CCDASH_ENTERPRISE_FILESYSTEM_INGESTION_ENABLED=false

# Optional bundled Postgres profile.
CCDASH_POSTGRES_DB=ccdash
CCDASH_POSTGRES_USER=ccdash
CCDASH_POSTGRES_PASSWORD=ccdash
CCDASH_POSTGRES_PORT=5432

# Observability and metrics.
CCDASH_OTEL_ENABLED=false
CCDASH_OTEL_ENDPOINT=http://localhost:4318
CCDASH_OTEL_SERVICE_NAME=ccdash-backend
CCDASH_PROM_PORT=9464

# Worker telemetry exporter.
CCDASH_TELEMETRY_EXPORT_ENABLED=false
CCDASH_SAM_ENDPOINT=
CCDASH_SAM_API_KEY=
CCDASH_TELEMETRY_ALLOW_INSECURE=false

# Frontend live-update toggles (read at Vite build time).
# See docs/guides/containerized-deployment-quickstart.md for SSE + polling fallback details.
# When SSE is disabled, frontend falls back to 30-second polling for features/tests/ops.
# For enterprise deployments, enable SSE when load balancer supports streaming (Nginx proxy_buffering off).
VITE_CCDASH_LIVE_EXECUTION_ENABLED=true
VITE_CCDASH_LIVE_SESSIONS_ENABLED=true
VITE_CCDASH_LIVE_SESSION_TRANSCRIPT_APPEND_ENABLED=false
# Feature board and modal live invalidation (set true to enable SSE, false to use 30s polling).
VITE_CCDASH_LIVE_FEATURES_ENABLED=false
# Test visualizer live invalidation (set true to enable SSE, false to use 30s polling).
VITE_CCDASH_LIVE_TESTS_ENABLED=false
# Operations panel live invalidation (set true to enable SSE, false to use 30s polling).
VITE_CCDASH_LIVE_OPS_ENABLED=false
# Backend gate for test live invalidation (must be true for test SSE delivery).
CCDASH_LIVE_TEST_UPDATES_ENABLED=true

# Live update transport tuning (SSE + polling fallback).
# When VITE_CCDASH_LIVE_FEATURES_ENABLED, VITE_CCDASH_LIVE_TESTS_ENABLED, or
# VITE_CCDASH_LIVE_OPS_ENABLED are false, frontend falls back to TanStack Query
# polling with a 30-second cadence.
# Tune these settings to match your deployment model:
# - Replay buffer: increase on high-concurrency deployments
# - Heartbeat: increase for unstable/slow networks
# - Pending events: balance between memory usage and invalidation timeliness
# CCDASH_LIVE_REPLAY_BUFFER_SIZE=200
# CCDASH_LIVE_HEARTBEAT_SECONDS=15
# CCDASH_LIVE_MAX_PENDING_EVENTS=100
# CCDASH_LIVE_COUNT_CACHE_TTL_SECONDS=10
# CCDASH_LIVE_AGENTS_WINDOW_SECONDS=600
