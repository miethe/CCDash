# Optional per-watcher env overlay for this CCDash repository.
#
# Usage:
#   docker compose \
#     --env-file deploy/runtime/.env \
#     --env-file deploy/runtime/watchers/ccdash.env \
#     -f deploy/runtime/compose.yaml \
#     --profile enterprise --profile postgres --profile live-watch up --build
#
# Keep this file copied as an untracked `.env`-style file for local paths.

CCDASH_WORKER_PROJECT_ID=3da60e0c-a928-4b78-abd7-a74731e995c6
CCDASH_WORKER_WATCH_PROBE_PORT=9466
CCDASH_STARTUP_SYNC_LIGHT_MODE=true
CCDASH_STARTUP_DEFERRED_REBUILD_LINKS=false
CCDASH_STARTUP_DEFERRED_CAPTURE_ANALYTICS=false

# Preserve absolute workspace paths while mounting agent homes under the
# container user's home so ~/.codex and ~/.claude paths resolve correctly.
CCDASH_PROJECTS_FILE=../../projects.json
CCDASH_WORKSPACE_HOST_ROOT=/Users/miethe/dev/homelab/development
CCDASH_WORKSPACE_CONTAINER_ROOT=/Users/miethe/dev/homelab/development

# This project currently points sessionsPath at ~/.codex/sessions/.
CCDASH_CODEX_HOME=/Users/miethe/.codex
CCDASH_CODEX_CONTAINER_HOME=/home/ccdash/.codex

# Mount Claude data as well so switching the project entry to Claude Code
# sessions does not require a compose change.
CCDASH_CLAUDE_HOME=/Users/miethe/.claude
CCDASH_CLAUDE_CONTAINER_HOME=/home/ccdash/.claude

# Enable when Docker Desktop does not deliver bind-mount filesystem events.
# WATCHFILES_FORCE_POLLING=true
