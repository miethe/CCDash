{
  "name": "ccdash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup": "node ./scripts/setup.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:frontend": "vite",
    "dev:backend": "node ./scripts/backend.mjs --runtime api --reload --host 127.0.0.1 --port 8000",
    "dev:worker": "node ./scripts/worker.mjs",
    "discover:sessions": "python3 backend/scripts/session_data_discovery.py --platform claude_code",
    "discover:claude-schema": "python3 backend/scripts/claude_session_schema_inventory.py",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "start:backend": "node ./scripts/backend.mjs --runtime api --host 0.0.0.0",
    "start:worker": "node ./scripts/worker.mjs",
    "start:frontend": "vite preview --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@miethe/ui": "^0.3.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.19",
    "@types/react-color": "^3.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-color": "^2.19.3",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
