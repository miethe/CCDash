{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Features",
  "type": "object",
  "required": ["categories"],
  "properties": {
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "items"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "description"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "highlight": { "type": "boolean", "default": false },
                "since": { "type": "string" },
                "cliCommand": { "type": "string" },
                "webPage": { "type": "string" },
                "screenshot": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
